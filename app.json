{
  "expo": {
    "name": "Nokka",
    "slug": "nokka",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nokka",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f12"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nokka.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Nokka needs camera access to scan barcodes and analyze meal photos with AI.",
        "NSPhotoLibraryUsageDescription": "Nokka needs photo library access to select meal photos for AI analysis.",
        "NSMicrophoneUsageDescription": "Nokka needs microphone access for video features."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f0f12"
      },
      "package": "com.nokka.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#c8f060",
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Nokka needs camera access to scan barcodes and analyze meal photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Nokka needs photo library access to select meal photos for AI analysis.",
          "cameraPermission": "Nokka needs camera access to take meal photos."
        }
      ],
      "expo-secure-store",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "NokkaWidget",
              "label": "Nokka",
              "description": "Calories et séances du jour",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetWidth": "250dp",
              "targetHeight": "120dp",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
